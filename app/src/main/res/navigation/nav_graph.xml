<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ── Bottom nav destinations ────────────────────────────────────────── -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.creesh.app.fragments.HomeFragment"
        android:label="Inicio">
        <action
            android:id="@+id/action_homeFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.creesh.app.fragments.ProfileFragment"
        android:label="Mi Perfil">
        <action
            android:id="@+id/action_profileFragment_to_chefProfileFragment"
            app:destination="@id/chefProfileFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- ── Screens accesibles desde Home ──────────────────────────────────── -->

    <fragment
        android:id="@+id/discoverFragment"
        android:name="com.creesh.app.fragments.DiscoverFragment"
        android:label="Descubrir">
        <action
            android:id="@+id/action_discoverFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/communitiesFragment"
        android:name="com.creesh.app.fragments.CommunitiesFragment"
        android:label="Comunidades">
        <action
            android:id="@+id/action_communitiesFragment_to_discoverFragment"
            app:destination="@id/discoverFragment"/>
    </fragment>

    <fragment
        android:id="@+id/uploadRecipeFragment"
        android:name="com.creesh.app.fragments.UploadRecipeFragment"
        android:label="Subir receta"/>

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.creesh.app.fragments.FavoritesFragment"
        android:label="Favoritos">
        <action
            android:id="@+id/action_favoritesFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- ── Pantallas de detalle (sin bottom nav) ───────────────────────────── -->

    <fragment
        android:id="@+id/recipeDetailFragment"
        android:name="com.creesh.app.fragments.RecipeDetailFragment"
        android:label="Receta">
        <action
            android:id="@+id/action_recipeDetailFragment_to_chefProfileFragment"
            app:destination="@id/chefProfileFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/chefProfileFragment"
        android:name="com.creesh.app.fragments.ChefProfileFragment"
        android:label="Cocinero">
        <action
            android:id="@+id/action_chefProfileFragment_to_recipeDetailFragment"
            app:destination="@id/recipeDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.creesh.app.fragments.SettingsFragment"
        android:label="Ajustes"/>

</navigation>
